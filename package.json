{
  "name": "diffy",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n web,convex -c blue,green \"bun --filter '@diffy/web' dev\" \"cd apps/web && bunx convex dev\"",
    "build": "bun --filter '*' build",
    "check": "bun --filter '*' check",
    "test": "bun --filter '*' test",
    "deploy": "bun --filter '@diffy/web' deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.5",
    "concurrently": "^9.2.1",
    "typescript": "^6.0.2"
  },
  "patchedDependencies": {
    "@pierre/trees@1.0.0-beta.3": "patches/@pierre%2Ftrees@1.0.0-beta.3.patch"
  }
}
