# Copy to .env.local (gitignored) and fill in.
# Most env vars actually live in apps/web/.env.local — this file documents the surface.

# --- Convex (auto-populated by `bunx convex dev` in apps/web) ---
# VITE_CONVEX_URL=https://<your-deployment>.convex.cloud
# CONVEX_DEPLOYMENT=dev:<your-deployment>

# --- Convex Auth: GitHub OAuth provider ---
# Register an OAuth app at https://github.com/settings/developers
# Callback URL: https://<your-convex-deployment>.convex.site/api/auth/callback/github
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# --- GitHub MCP server (developer-side, not shipped to prod) ---
# Personal Access Token used by the GitHub MCP server in .mcp.json.
# Scope: public_repo is enough for Diffy's API needs; use repo if you want the MCP
# to also manage your private repos.
# GITHUB_PERSONAL_ACCESS_TOKEN=
